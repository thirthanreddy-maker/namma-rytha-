{
  "expo": {
    "name": "Namma Rytha",
    "slug": "nammarytha",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nammarytha",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nammarytha.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#050a05",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "package": "com.nammarytha.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050a05",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
