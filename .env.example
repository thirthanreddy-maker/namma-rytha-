# ──────────────────────────────────────────────────────────────────
# Namma Rytha – Environment Variables Template
# Copy this file to `.env` and fill in your values.
# NEVER commit the actual `.env` file to version control.
# ──────────────────────────────────────────────────────────────────

# ── MongoDB ────────────────────────────────────────────────────────
# Local development (default – no value needed if running local Mongo)
MONGO_URI=mongodb://127.0.0.1:27017/nammarytha

# MongoDB Atlas (production) – replace with your actual connection string
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nammarytha?retryWrites=true&w=majority

# ── Server ─────────────────────────────────────────────────────────
PORT=3000

# ── Google OAuth ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Node ───────────────────────────────────────────────────────────
NODE_ENV=development
